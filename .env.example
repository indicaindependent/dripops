# DripOps environment template — copy to .env and fill in your own values.
# DO NOT COMMIT .env.

# === Bridge worker (set via `wrangler secret put`, not .env) ===
# DRIPOPS_INGEST_KEY=<64-char hex>
# SPLUNK_HEC_URL=https://http-inputs-<your-stack>.splunkcloud.com/services/collector/event
# SPLUNK_HEC_TOKEN=<from Splunk UI: Data Inputs → HTTP Event Collector>
# SPLUNK_API_URL=https://<your-stack>.splunkcloud.com:8089
# SPLUNK_SEARCH_TOKEN=<from Splunk UI: Settings → Tokens>
# SSHMCP_RELAY_URL=https://<your-relay>.example.com/exec
# SSHMCP_SECRET=<shared secret>

# === Sources (Python + CF Workers) ===
DRIPOPS_INGEST_KEY=
BRIDGE_URL=https://dripops-splunk-hec-bridge.YOUR-CF-SUBDOMAIN.workers.dev

# === Agent host ===
ANTHROPIC_API_KEY=
DRIPOPS_MODEL=claude-sonnet-4-5-20250929
GITHUB_TOKEN=
GITHUB_REPO=YOUR_GH_USER/dripops

# === Telegram (alerts target) ===
TELEGRAM_BOT_TOKEN=
TG_CHAT_ID=
